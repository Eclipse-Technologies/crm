# Production environment template for GoDaddy deployment
# Copy this file to .env on the server and replace all <...> values.

# Database (production)
DB_HOST=localhost
DB_NAME=crmdb
DB_USER=<local_db_user_or_same_as_prod>
DB_PASSWORD=<local_db_password_or_same_as_prod>
PROD_DB_HOST=<godaddy_db_host>
PROD_DB_NAME=<godaddy_db_name>
PROD_DB_USER=<godaddy_db_user>
PROD_DB_PASSWORD=<godaddy_db_password>

# Backup settings
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
BACKUP_RETENTION_COUNT=50
AUDIT_BACKUP_DIR=backups/audit/

# API security (comma-separated strong random keys)
API_KEYS=<long_random_key_1>,<long_random_key_2>

# Daily call workflow
DAILY_CALL_EMAIL_TO=<owner_email@example.com>
DAILY_CALL_BASE_URL=<https://crm.yourdomain.com>
DAILY_CALL_LINK_SECRET=<long_random_secret>
DAILY_CALL_LINK_MAX_AGE_SECONDS=1209600
APP_BASE_URL=<https://crm.yourdomain.com>
AUTH_SESSION_COOKIE_SECURE=true

# Email transport (choose one option)

# Option A: GoDaddy hosted local relay (typically server-side only)
# SMTP_HOST=localhost
# SMTP_PORT=25
# SMTP_AUTH=false
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_ENCRYPTION=none

# Option B: External authenticated SMTP
SMTP_HOST=<smtp_host>
SMTP_PORT=587
SMTP_AUTH=true
SMTP_USERNAME=<smtp_username>
SMTP_PASSWORD=<smtp_password>
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=<from_email@example.com>
SMTP_FROM_NAME=<CRM Team>

# Option C: Microsoft Graph mail transport
# MAIL_TRANSPORT=graph
# GRAPH_TENANT_ID=<tenant_id>
# GRAPH_CLIENT_ID=<client_id>
# GRAPH_CLIENT_SECRET=<client_secret>
# GRAPH_SENDER=<sender_mailbox@example.com>
