<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <defaultDocument>
            <files>
                <add value="index.php" />
            </files>
        </defaultDocument>
        <security>
            <requestFiltering>
                <hiddenSegments>
                    <add segment="DEPRICATED" />
                    <add segment="libraries" />
                    <add segment="setup" />
                </hiddenSegments>
            </requestFiltering>
        </security>
    </system.webServer>
</configuration>
