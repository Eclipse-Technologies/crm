# Example environment file for CRM
# Copy to .env and fill in your values
DB_HOST=localhost
DB_NAME=cmrdb
DB_USER=root
DB_PASSWORD=changeme
PROD_DB_HOST=localhost
PROD_DB_NAME=cmrdb
PROD_DB_USER=crm_admin
PROD_DB_PASSWORD=changeme
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
BACKUP_RETENTION_COUNT=50
AUDIT_BACKUP_DIR=backups/audit/
API_KEYS=replace_with_long_random_key_1,replace_with_long_random_key_2
DAILY_CALL_EMAIL_TO=your_email@example.com
DAILY_CALL_BASE_URL=https://yourdomain.com
DAILY_CALL_LINK_SECRET=replace_with_long_random_secret
DAILY_CALL_LINK_MAX_AGE_SECONDS=1209600
APP_BASE_URL=https://yourdomain.com
AUTH_SESSION_COOKIE_SECURE=true

# SMTP settings for mass_email.php
#
# Option 1: GoDaddy hosted local relay (use this on GoDaddy hosting)
# SMTP_HOST=localhost
# SMTP_PORT=25
# SMTP_AUTH=false
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_ENCRYPTION=none
#
# Option 2: External authenticated SMTP
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_AUTH=true
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_ENCRYPTION=tls

# Option 3: Microsoft Graph mail transport
# MAIL_TRANSPORT=graph
# GRAPH_TENANT_ID=your_tenant_id
# GRAPH_CLIENT_ID=your_app_client_id
# GRAPH_CLIENT_SECRET=your_app_client_secret
# GRAPH_SENDER=your_mailbox@example.com
